# =============================================================================
# HodorInfo Backend – .gitignore
# Node.js / TypeScript / Express / Prisma
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment Variables ─────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.staging
.env.production
.env.test
*.env

# ── Build / Compiled Output ───────────────────────────────────────────────────
dist/
build/
out/
*.js.map
*.d.ts.map

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Prisma ────────────────────────────────────────────────────────────────────
# Generated client
/generated/
node_modules/.prisma/

# Local SQLite databases (if used for testing/local dev)
*.db
*.db-journal
*.sqlite

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Runtime / Process ─────────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ── Coverage / Testing ────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
lib-cov/

# ── Cache ─────────────────────────────────────────────────────────────────────
.npm/
.eslintcache
.stylelintcache
.cache/
.parcel-cache/
.turbo/

# ── OS Generated Files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────────────────────
*.local
.vercel
.railway
